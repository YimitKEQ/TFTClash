# ── Discord ──────────────────────────────────────────────────────────────────
# Get these from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_id_here

# The Guild (server) ID — right-click server icon → Copy Server ID
GUILD_ID=your_server_id_here

# ── Supabase (required for live data) ────────────────────────────────────────
# Get from Supabase dashboard → Settings → API
# Use the SERVICE ROLE key here — the bot has full DB write access
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Bot Behaviour ─────────────────────────────────────────────────────────────
# Timezone for scheduled posts (e.g. Europe/London, America/New_York)
TIMEZONE=Europe/London
