# TFT Clash — Environment Variables
# Copy to .env and fill in your values
# Never commit .env to git!

# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side Supabase URL (for Vercel serverless functions like paypal-webhook)
# Same value as VITE_SUPABASE_URL, but accessible in server-side code
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── PayPal (for Pro/Scrim/Bundle/Host subscriptions) ────────────────────────
# Get from: https://developer.paypal.com/dashboard/applications
# Use Sandbox credentials for development, Live for production
VITE_PAYPAL_CLIENT_ID=your-paypal-client-id

# Create Subscription Plans in PayPal dashboard, then copy the Plan IDs
# Dashboard: https://developer.paypal.com/dashboard/applications > Subscriptions
VITE_PAYPAL_PLAN_PRO=P-your-pro-plan-id
VITE_PAYPAL_PLAN_SCRIM=P-your-scrim-plan-id
VITE_PAYPAL_PLAN_BUNDLE=P-your-bundle-plan-id
VITE_PAYPAL_PLAN_HOST=P-your-host-plan-id

# Server-side PayPal credentials (for webhook handler - set in Vercel env vars)
# These MUST be set separately from VITE_ vars since VITE_ is client-side only
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_WEBHOOK_ID=your-webhook-id
PAYPAL_PLAN_PRO=P-your-pro-plan-id
PAYPAL_PLAN_SCRIM=P-your-scrim-plan-id
PAYPAL_PLAN_BUNDLE=P-your-bundle-plan-id
PAYPAL_PLAN_HOST=P-your-host-plan-id

# ── Admin ────────────────────────────────────────────────────────────────────
# Password for the admin panel (set in Vercel dashboard, not here)
# ADMIN_PASSWORD=set-this-in-vercel-dashboard

# ── Cron / SEO ping secret ───────────────────────────────────────────────────
# Required by api/cron-retention-notify.js (manual invoke) and api/ping-search-engines.js
# Set in Vercel dashboard. Cron-scheduled invocations bypass via x-vercel-cron header.
# PING_SECRET=generate-a-random-32-char-string

# ── Discord Bot (set in discord-bot/.env) ────────────────────────────────────
# DISCORD_TOKEN=your-bot-token
# CLIENT_ID=your-client-id
# GUILD_ID=your-server-id
# TIMEZONE=Europe/London
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key (never use anon key for bot)
