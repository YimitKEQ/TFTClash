# TFT Clash — Environment Variables
# Copy to .env and fill in your values
# Never commit .env to git!

# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Stripe (for Pro/Host subscriptions) ─────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) for development, live keys (sk_live_...) for production
STRIPE_SECRET_KEY=sk_test_your-key-here

# Create products in Stripe dashboard, then copy the Price IDs
# Each product needs 2 prices: monthly and annual
STRIPE_PRO_PRICE_ID=price_your-pro-monthly-price-id
STRIPE_PRO_ANNUAL_PRICE_ID=price_your-pro-annual-price-id
STRIPE_HOST_PRICE_ID=price_your-host-monthly-price-id
STRIPE_HOST_ANNUAL_PRICE_ID=price_your-host-annual-price-id

# Webhook secret — get from Stripe dashboard after creating the webhook endpoint
# Endpoint URL: https://your-domain.vercel.app/api/stripe-webhook
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ── Admin ────────────────────────────────────────────────────────────────────
# Password for the admin panel (set in Vercel dashboard, not here)
# ADMIN_PASSWORD=set-this-in-vercel-dashboard

# ── Discord Bot (set in discord-bot/.env) ────────────────────────────────────
# DISCORD_TOKEN=your-bot-token
# CLIENT_ID=your-client-id
# GUILD_ID=your-server-id
# TIMEZONE=Europe/London
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key (never use anon key for bot)
